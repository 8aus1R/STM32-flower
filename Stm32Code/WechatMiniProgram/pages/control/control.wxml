<view class="page">
  <view class="panel">
    <view class="panel-title">MQTT Status</view>
    <view class="status-line">
      <text class="status-dot {{statusClass}}"></text>
      <text>{{statusText}}</text>
    </view>
    <view class="muted">Device: {{deviceStatus}}</view>
  </view>

  <view class="panel">
    <view class="panel-title">Pump Control</view>
    <view class="button-row">
      <button class="primary-btn" data-cmd="pump_on" bindtap="sendCommand">Pump On</button>
      <button class="danger-btn" data-cmd="pump_off" bindtap="sendCommand">Pump Off</button>
    </view>
  </view>

  <view class="panel">
    <view class="panel-title">Recent Logs</view>
    <view class="log-list">
      <block wx:for="{{logs}}" wx:key="*this">
        <view class="log-item">{{item}}</view>
      </block>
    </view>
  </view>
</view>

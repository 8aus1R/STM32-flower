.status-line {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  margin-bottom: 14rpx;
}

.device-line {
  font-size: 26rpx;
}

.top-actions {
  margin-top: 24rpx;
}

.metrics-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.metric-card {
  background: #ffffff;
  border: 1rpx solid #dde6df;
  border-radius: 12rpx;
  padding: 24rpx;
  min-height: 150rpx;
  box-sizing: border-box;
}

.metric-label {
  font-size: 26rpx;
  color: #667085;
  margin-bottom: 20rpx;
}

.metric-value {
  font-size: 46rpx;
  font-weight: 800;
  color: #1f6f4a;
}

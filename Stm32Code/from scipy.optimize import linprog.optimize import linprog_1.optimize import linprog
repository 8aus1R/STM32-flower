from scipy.optimize import linprog

# 目标函数系数（因为linprog默认求最小值，所以这里取负数）
c = [-3, -2]

# 不等式约束条件系数（左侧）
A = [
    [2, 1],   # 2x₁ + x₂ ≤ 100
    [1, 1],   # x₁ + x₂ ≤ 80
    [1, 0]    # x₁ ≤ 40
]

# 不等式约束条件右侧
b = [100, 80, 40]

# 变量取值范围 (x₁, x₂ ≥ 0)
x0_bounds = (0, None)
x1_bounds = (0, None)
bounds = [x0_bounds, x1_bounds]

# 求解
result = linprog(c, A_ub=A, b_ub=b, bounds=bounds, method='highs')

print(f"最优解: x1 = {result.x[0]}, x2 = {result.x[1]}")
print(f"目标函数最大值: {-result.fun}")
